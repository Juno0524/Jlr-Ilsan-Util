{
  "manifest_version": 3,
  "name": "JLR Ilsan Helper",
  "version": "3.6",
  "description": "One DMS 업무를 빠르게 처리할 수 있도록 내부의견 입력, 작업그룹 처리, 배출가스 부품 조회를 지원하는 보조 도구입니다.",
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "action": {
    "default_title": "JLR Ilsan Helper",
    "default_icon": {
      "16": "icon-16.png",
      "32": "icon-32.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    },
    "default_popup": "options.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage", "activeTab", "alarms"],
  "host_permissions": [
    "https://juno0524.github.io/*",
    "https://jlr-settings-admin.vercel.app/*",
    "https://*.vercel.app/*"
  ],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["https://www.jlrkdms.co.kr/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ]
}
